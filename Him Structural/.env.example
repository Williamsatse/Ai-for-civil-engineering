# Template de variables d'environnement
# Copiez ce fichier en .env et remplacez les valeurs
# NE JAMAIS COMMIT CE FICHIER AVEC DES VRAIES VALEURS

# Token GitHub pour l'API (uniquement pour développement local)
GITHUB_TOKEN=votre_token_github_ici

# Configuration de l'application
APP_ENV=development
APP_DEBUG=true

# Chemins de données
DATA_PATH=./data
OUTPUT_PATH=./output

# Paramètres de calcul
DEFAULT_NORM=Eurocode
DEFAULT_LANGUAGE=fr
