<Window x:Class="HimFoster.ChatWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Him Assistant"
        Height="750"
        Width="1100"
        Background="#FF1E1E2E"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanResize"
        WindowStyle="None">

	<!-- ===================== -->
	<!--        STYLES         -->
	<!-- ===================== -->
	<Window.Resources>

		<!-- Bouton moderne -->
		<Style x:Key="ModernButtonStyle" TargetType="Button">
			<Setter Property="Background" Value="#FF89B4FA"/>
			<Setter Property="Foreground" Value="#FF1E1E2E"/>
			<Setter Property="BorderThickness" Value="0"/>
			<Setter Property="Cursor" Value="Hand"/>
			<Setter Property="Template">
				<Setter.Value>
					<ControlTemplate TargetType="Button">
						<Border Background="{TemplateBinding Background}"
                                CornerRadius="6">
							<ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
						</Border>
					</ControlTemplate>
				</Setter.Value>
			</Setter>
		</Style>

		<!-- Bouton envoyer -->
		<Style x:Key="SendButtonStyle"
               TargetType="Button"
               BasedOn="{StaticResource ModernButtonStyle}">
			<Setter Property="Width" Value="40"/>
			<Setter Property="Height" Value="40"/>
			<Setter Property="Template">
				<Setter.Value>
					<ControlTemplate TargetType="Button">
						<Border Background="{TemplateBinding Background}"
                                CornerRadius="20">
							<Path Data="M2,21 L21,12 L2,3 L6,12 Z"
                                  Fill="#FF1E1E2E"
                                  Width="18"
                                  Height="18"
                                  Stretch="Uniform"
                                  HorizontalAlignment="Center"
                                  VerticalAlignment="Center"/>
						</Border>
					</ControlTemplate>
				</Setter.Value>
			</Setter>
		</Style>

		<!-- TextBox -->
		<Style TargetType="TextBox">
			<Setter Property="Background" Value="#FF313244"/>
			<Setter Property="Foreground" Value="#FFCDD6F4"/>
			<Setter Property="BorderBrush" Value="#FF45475A"/>
			<Setter Property="BorderThickness" Value="1"/>
			<Setter Property="Padding" Value="10"/>
			<Setter Property="FontSize" Value="14"/>
		</Style>

	</Window.Resources>

	<!-- ===================== -->
	<!--        LAYOUT         -->
	<!-- ===================== -->
	<Grid>
		<Grid.RowDefinitions>
			<RowDefinition Height="32"/>
			<RowDefinition Height="*"/>
			<RowDefinition Height="Auto"/>
		</Grid.RowDefinitions>

		<!-- Barre de titre -->
		<Grid Grid.Row="0" Background="#FF181825"
              MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
			<TextBlock Text="Him Assistant"
                       Foreground="#FFCDD6F4"
                       VerticalAlignment="Center"
                       Margin="10,0,0,0"/>
		</Grid>

		<!-- Historique du chat -->
		<ScrollViewer Grid.Row="1"
                      Margin="10"
                      VerticalScrollBarVisibility="Auto">

			<!-- IMPORTANT : StackPanel compatible avec ChatContainer.Children.Add -->
			<StackPanel x:Name="ChatContainer"/>
		</ScrollViewer>

		<!-- Zone de saisie -->
		<DockPanel Grid.Row="2" Margin="10">

			<Button x:Name="SendButton"
                    DockPanel.Dock="Right"
                    Style="{StaticResource SendButtonStyle}"
                    Click="SendButton_Click"
                    Margin="8,0,0,0"/>

			<TextBox x:Name="UserInput"
                     Height="40"
                     VerticalContentAlignment="Center"
                     KeyDown="UserInput_KeyDown"/>
		</DockPanel>

	</Grid>
</Window>
