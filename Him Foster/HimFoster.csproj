<Project Sdk="Microsoft.NET.Sdk">

	<PropertyGroup>
		<TargetFramework>net8.0-windows</TargetFramework>
		<Nullable>enable</Nullable>
		<ImplicitUsings>enable</ImplicitUsings>
		<UseWPF>true</UseWPF>
		<Platforms>x64</Platforms>
		<PlatformTarget>x64</PlatformTarget>
		<RestorePackagesWithLockFile>true</RestorePackagesWithLockFile>
		<AutoGenerateBindingRedirects>true</AutoGenerateBindingRedirects>
		<ProduceBindingRedirectsOutputType>true</ProduceBindingRedirectsOutputType>
	</PropertyGroup>


	<ItemGroup>
		<PackageReference Include="Newtonsoft.Json" Version="13.0.3" />
		<PackageReference Include="System.Drawing.Common" Version="8.0.10" />
		<!-- Références Revit : uniquement ces deux-là -->
		<Reference Include="RevitAPI">
			<HintPath>$(ProgramFiles)\Autodesk\Revit 2026\RevitAPI.dll</HintPath>
			<Private>false</Private>
		</Reference>
		<Reference Include="RevitAPIUI">
			<HintPath>$(ProgramFiles)\Autodesk\Revit 2026\RevitAPIUI.dll</HintPath>
			<Private>false</Private>
		</Reference>
	</ItemGroup>

	<!-- Pas de références vers les Facades .NET Framework, 
       pas de package NuGet System.Security.Cryptography.Primitives -->
</Project>
